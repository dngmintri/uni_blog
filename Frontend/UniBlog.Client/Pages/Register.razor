@page "/register"
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Đăng ký - UniBlog</PageTitle>

<div class="auth-container">
    <div class="auth-card card">
        <h1>Đăng ký tài khoản</h1>
        <p class="auth-subtitle">Tham gia cộng đồng UniBlog ngay hôm nay!</p>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        @if (success)
        {
            <div class="alert alert-success">
                Đăng ký thành công! Đang chuyển hướng đến trang đăng nhập...
            </div>
        }

        <EditForm Model="registerRequest" OnValidSubmit="HandleRegister">
            <DataAnnotationsValidator />
            <ValidationSummary class="alert alert-danger" />

            <div class="form-group">
                <label class="form-label">Username *</label>
                <InputText @bind-Value="registerRequest.Username" class="form-control" />
            </div>

            <div class="form-group">
                <label class="form-label">Email</label>
                <InputText type="email" @bind-Value="registerRequest.Email" class="form-control" />
            </div>

            <div class="form-group">
                <label class="form-label">Họ tên</label>
                <InputText @bind-Value="registerRequest.FullName" class="form-control" />
            </div>

            <div class="form-group">
                <label class="form-label">Password *</label>
                <InputText type="password" @bind-Value="registerRequest.Password" class="form-control" />
            </div>

            <div class="form-group">
                <label class="form-label">Xác nhận Password *</label>
                <InputText type="password" @bind-Value="registerRequest.ConfirmPassword" class="form-control" />
            </div>

            <div class="form-group">
                <label class="form-label">Giới tính</label>
                <InputSelect @bind-Value="registerRequest.Gender" class="form-control">
                    <option value="">-- Chọn giới tính --</option>
                    <option value="Nam">Nam</option>
                    <option value="Nữ">Nữ</option>
                    <option value="Khác">Khác</option>
                </InputSelect>
            </div>

            <div class="form-group">
                <label class="form-label">Ngày sinh</label>
                <InputDate @bind-Value="registerRequest.DateOfBirth" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary btn-full" disabled="@loading">
                @if (loading)
                {
                    <span>Đang đăng ký...</span>
                }
                else
                {
                    <span>Đăng ký</span>
                }
            </button>
        </EditForm>

        <div class="auth-footer">
            <p>Đã có tài khoản? <a href="/login">Đăng nhập ngay</a></p>
        </div>
    </div>
</div>

@code {
    private RegisterRequest registerRequest = new();
    private string errorMessage = string.Empty;
    private bool loading = false;
    private bool success = false;

    private async Task HandleRegister()
    {
        loading = true;
        errorMessage = string.Empty;

        var result = await AuthService.RegisterAsync(registerRequest);

        if (result)
        {
            success = true;
            await Task.Delay(2000);
            Navigation.NavigateTo("/login");
        }
        else
        {
            errorMessage = "Đăng ký thất bại. Username hoặc email có thể đã tồn tại.";
        }

        loading = false;
    }
}

<style>
    .auth-container {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 2rem 0;
    }

    .auth-card {
        max-width: 500px;
        width: 100%;
    }

    .auth-card h1 {
        text-align: center;
        margin-bottom: 0.5rem;
    }

    .auth-subtitle {
        text-align: center;
        color: var(--text-secondary);
        margin-bottom: 2rem;
    }

    .btn-full {
        width: 100%;
        margin-top: 1rem;
    }

    .auth-footer {
        text-align: center;
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border-color);
    }

    .auth-footer a {
        color: var(--primary-color);
        text-decoration: none;
        font-weight: 600;
    }

    .auth-footer a:hover {
        text-decoration: underline;
    }
</style>

