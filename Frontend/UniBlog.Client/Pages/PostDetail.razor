@page "/posts/{PostId:int}"
@inject IPostService PostService
@inject ICommentService CommentService
@inject NavigationManager Navigation
@attribute [Authorize]

<PageTitle>@(post?.Title ?? "Chi tiết bài viết") - UniBlog</PageTitle>

@if (loading)
{
    <div class="loading-container">
        <div class="spinner"></div>
        <p>Đang tải bài viết...</p>
    </div>
}
else if (post == null)
{
    <div class="alert alert-danger">
        Không tìm thấy bài viết.
    </div>
}
else
{
    <div class="post-detail">
        <div class="post-header">
            <h1>@post.Title</h1>
            <div class="post-meta">
                <span>👤 @(post.AuthorName ?? "Anonymous")</span>
                <span>📅 @post.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                <span>👁️ @post.Views lượt xem</span>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(post.ImageUrl))
        {
            <img src="@post.ImageUrl" alt="@post.Title" class="post-detail-image" />
        }

        <div class="post-content">
            @((MarkupString)post.Content.Replace("\n", "<br />"))
        </div>

        <div class="comments-section">
            <h2>💬 Bình luận (@comments.Count)</h2>

            <div class="comment-form card">
                <EditForm Model="newComment" OnValidSubmit="HandleAddComment">
                    <DataAnnotationsValidator />
                    <div class="form-group">
                        <InputTextArea @bind-Value="newComment.Content" class="form-control" 
                            placeholder="Viết bình luận của bạn..." />
                    </div>
                    <button type="submit" class="btn btn-primary">Gửi bình luận</button>
                </EditForm>
            </div>

            @if (comments.Any())
            {
                <div class="comments-list">
                    @foreach (var comment in comments)
                    {
                        <div class="comment">
                            <div class="comment-header">
                                <span class="comment-author">@comment.Username</span>
                                <span class="comment-date">@comment.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <p>@comment.Content</p>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted">Chưa có bình luận nào. Hãy là người đầu tiên bình luận!</p>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public int PostId { get; set; }

    private PostDto? post;
    private List<CommentDto> comments = new();
    private CreateCommentDto newComment = new();
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadPost();
        await LoadComments();
    }

    private async Task LoadPost()
    {
        loading = true;
        post = await PostService.GetPostByIdAsync(PostId);
        loading = false;
    }

    private async Task LoadComments()
    {
        comments = await CommentService.GetCommentsByPostIdAsync(PostId);
    }

    private async Task HandleAddComment()
    {
        newComment.PostId = PostId;
        var result = await CommentService.CreateCommentAsync(newComment);
        
        if (result != null)
        {
            newComment = new CreateCommentDto();
            await LoadComments();
        }
    }
}

<style>
    .post-detail {
        max-width: 800px;
        margin: 0 auto;
    }

    .post-header {
        margin-bottom: 2rem;
    }

    .post-header h1 {
        font-size: 2rem;
        margin-bottom: 1rem;
    }

    .post-meta {
        display: flex;
        gap: 1.5rem;
        color: var(--text-secondary);
        font-size: 0.875rem;
    }

    .post-detail-image {
        width: 100%;
        max-height: 400px;
        object-fit: cover;
        border-radius: 0.75rem;
        margin-bottom: 2rem;
    }

    .post-content {
        font-size: 1.125rem;
        line-height: 1.8;
        margin-bottom: 3rem;
    }

    .comments-section {
        border-top: 2px solid var(--border-color);
        padding-top: 2rem;
    }

    .comments-section h2 {
        margin-bottom: 1.5rem;
    }

    .comment-form {
        margin-bottom: 2rem;
    }

    .comments-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .text-muted {
        color: var(--text-secondary);
        text-align: center;
        padding: 2rem 0;
    }
</style>


